# ============================================================
# DATABASE CONFIGURATION
# ============================================================
#
# DB_MODE controls which database the app connects to:
#   cloud  → uses CLOUD_DATABASE_URL (Neon)
#   local  → uses LOCAL_DATABASE_URL  (local PostgreSQL)
#
# Copy this file to .env and fill in your values.
# ============================================================

DB_MODE=cloud

# Cloud database — Neon (get this from https://console.neon.tech)
CLOUD_DATABASE_URL=postgresql://<user>:<password>@<host>/neondb?sslmode=require

# Local database — PostgreSQL running on your machine
LOCAL_DATABASE_URL=postgresql://postgres:<password>@localhost:5432/<dbname>

# Legacy fallback (used if DB_MODE is not set)
DATABASE_URL=postgresql://postgres:<password>@localhost:5432/<dbname>

# ============================================================
# APP CONFIGURATION
# ============================================================

# Generate a strong random string: openssl rand -hex 64
SESSION_SECRET=<your-session-secret>

PORT=8085

# Frontend Vite dev server port (must differ from PORT)
VITE_PORT=5173

# Base path for the frontend app (/ for local dev)
BASE_PATH=/

NODE_ENV=development
HTTPS=false
